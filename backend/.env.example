# PostgreSQL credentials (fictitious placeholders)
POSTGRES_USER=change_me_user
POSTGRES_PASSWORD=change_me_password
POSTGRES_DB=change_me_db

# Connection string for Prisma (use URL‑encoded password if it contains special characters)
DATABASE_URL="postgresql://$POSTGRES_USER:$POSTGRES_PASSWORD@localhost:5432/$POSTGRES_DB?schema=public"

# JWT secrets (generate with `openssl rand -hex 32`)
JWT_SECRET=change_me_jwt_secret
JWT_REFRESH_SECRET=change_me_jwt_refresh_secret

# Aplicação
# Endereço de binding da API (default 127.0.0.1). Use 127.0.0.1 quando o Caddy estiver no mesmo servidor; não use 0.0.0.0 em homologação ou produção. O acesso externo ocorre via Caddy nas portas 80/443.
API_BIND_ADDRESS=127.0.0.1
APP_PORT=3000
NODE_ENV=development
CORS_ORIGIN="http://localhost:3001,http://localhost:5173"

# Token temporário para QR Code (segundos)
QR_TOKEN_SECRET=change_me_qr_secret
QR_TOKEN_EXPIRES_IN_SECONDS=30

# HMAC secret para hash de CPF (mínimo 32 caracteres)
CUSTOMER_PII_HMAC_SECRET=change_me_hmac_secret

# Apenas para desenvolvimento/testing – não é usado em homologação ou produção.
# RBAC_SEED_PASSWORD=change_me_seed_password
