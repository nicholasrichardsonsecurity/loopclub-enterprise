```env
# Banco de dados local de desenvolvimento
DATABASE_URL="postgresql://postgres:change_me@localhost:5432/loopclub?schema=public"

# Autenticação
JWT_SECRET="change_me"
JWT_REFRESH_SECRET="change_me"

# Aplicação
APP_PORT=3000
NODE_ENV=development
CORS_ORIGIN="http://localhost:3001,http://localhost:5173"

# Planejado para tokens temporários de QR Code
# Unidade atual: segundos
QR_TOKEN_SECRET="change_me"
QR_TOKEN_EXPIRES_IN_SECONDS=30

# ⚠️ USO EXCLUSIVO LOCAL
# Senha usada somente pelo seed de testes RBAC.
# O seed é permitido apenas em NODE_ENV=development ou NODE_ENV=test.
# Nunca reutilizar essa senha em produção.
# Nunca colocar valor real neste arquivo.
RBAC_SEED_PASSWORD=
```
