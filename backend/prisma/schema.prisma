generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  company_owner
  employee
  client
}

enum UserStatus {
  active
  blocked
  deleted
}

enum CompanyStatus {
  active
  blocked
  trial
  canceled
}

enum CompanyUserRole {
  owner
  manager
  employee
}

enum LoyaltyProgramType {
  buy_x_get_y
  progressive
}

enum TransactionType {
  qr_point
  manual_point
  remove_point
  reset
  reward_redeemed
}

model User {
  id           String       @id @default(uuid())
  name         String
  phone        String?      @unique
  email        String?      @unique
  passwordHash String?
  role         UserRole
  status       UserStatus   @default(active)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  companyUsers CompanyUser[]
  clientProgress LoyaltyProgress[] @relation("ClientProgress")
  operatedTransactions Transaction[] @relation("OperatorTransactions")
  clientTransactions Transaction[] @relation("ClientTransactions")
}

model Company {
  id             String        @id @default(uuid())
  name           String
  document       String?       @unique
  category       String
  phone          String?
  email          String?
  ownerName      String?
  status         CompanyStatus @default(trial)
  logoUrl        String?
  primaryColor   String        @default("#6F13A5")
  secondaryColor String        @default("#CF00FF")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  users          CompanyUser[]
  programs       LoyaltyProgram[]
  subscriptions  Subscription[]
  progress       LoyaltyProgress[]
  transactions   Transaction[]
}

model CompanyUser {
  id        String          @id @default(uuid())
  companyId String
  userId    String
  role      CompanyUserRole
  status    UserStatus      @default(active)
  createdAt DateTime        @default(now())

  company   Company @relation(fields: [companyId], references: [id])
  user      User    @relation(fields: [userId], references: [id])

  @@unique([companyId, userId])
  @@index([companyId])
  @@index([userId])
}

model Plan {
  id          String   @id @default(uuid())
  name        String
  price       Decimal  @db.Decimal(10,2)
  maxClients  Int?
  maxPrograms Int?
  features    Json?
  status      String   @default("active")
  createdAt   DateTime @default(now())

  subscriptions Subscription[]
}

model Subscription {
  id        String   @id @default(uuid())
  companyId String
  planId    String
  price     Decimal  @db.Decimal(10,2)
  status    String   @default("active")
  dueDate   DateTime?
  paidUntil DateTime?
  notes     String?
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])
  plan    Plan    @relation(fields: [planId], references: [id])

  @@index([companyId])
  @@index([status])
}

model LoyaltyProgram {
  id                String             @id @default(uuid())
  companyId          String
  name              String
  description       String?
  type              LoyaltyProgramType
  targetPoints      Int
  rewardName        String
  rewardDescription String?
  status            String             @default("active")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  company    Company @relation(fields: [companyId], references: [id])
  milestones LoyaltyMilestone[]
  progress   LoyaltyProgress[]
  transactions Transaction[]

  @@index([companyId])
}

model LoyaltyMilestone {
  id                String @id @default(uuid())
  programId          String
  pointsRequired     Int
  rewardName         String
  rewardDescription  String?

  program LoyaltyProgram @relation(fields: [programId], references: [id])

  @@index([programId])
}

model LoyaltyProgress {
  id              String   @id @default(uuid())
  companyId       String
  programId       String
  clientId        String
  currentPoints   Int      @default(0)
  completedCycles Int      @default(0)
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  program LoyaltyProgram @relation(fields: [programId], references: [id])
  client  User @relation("ClientProgress", fields: [clientId], references: [id])

  @@unique([programId, clientId])
  @@index([companyId])
  @@index([clientId])
}

model Transaction {
  id          String          @id @default(uuid())
  companyId   String
  programId   String?
  clientId    String
  operatorId  String?
  type        TransactionType
  points      Int             @default(0)
  description String?
  createdAt   DateTime        @default(now())

  company  Company @relation(fields: [companyId], references: [id])
  program  LoyaltyProgram? @relation(fields: [programId], references: [id])
  client   User @relation("ClientTransactions", fields: [clientId], references: [id])
  operator User? @relation("OperatorTransactions", fields: [operatorId], references: [id])

  @@index([companyId])
  @@index([clientId])
  @@index([createdAt])
}

model QrToken {
  id        String   @id @default(uuid())
  companyId String
  clientId  String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  status    String   @default("active")
  createdAt DateTime @default(now())

  @@index([tokenHash])
  @@index([expiresAt])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  companyId String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([createdAt])
}
